#!/usr/bin/env bash
set -euo pipefail

REPO="arch4edu/cactus"
OUTPUT_DIR="/tmp"
FULL_LOG=false
RAW=false

usage() {
    local code="${1:-0}"
    cat <<'EOF'
Usage: save-log <workflow-run-id> [-R owner/repo] [-o output-dir] [-f] [-r]

Save build logs from arch4edu/cactus GitHub Actions workflow runs.

By default, saves only the "Build" step from the workflow log, stripping
timestamps, ANSI color codes, and GitHub Actions boilerplate (action config,
script echo). Use -f for the full unfiltered log, -r to keep raw formatting.

Arguments:
  <workflow-run-id>   The numeric workflow run ID (required)

Options:
  -R <owner/repo>     Repository to query (default: arch4edu/cactus)
  -o <dir>            Output directory (default: /tmp)
  -f                  Save the full workflow log (no build-step filtering)
  -r                  Raw output: keep timestamps and ANSI codes
  -h                  Show this help

Output:
  Saves the log to <output-dir>/<workflow-run-id>.log

Examples:
  save-log 27096257642
  save-log 27096257642 -f
  save-log 27096257642 -R arch4edu/cactus -o ~/logs
  save-log 27096257642 -r
EOF
    exit "$code"
}

WORKFLOW_ID=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -R)
            [[ $# -ge 2 ]] || { echo "Error: -R requires a value" >&2; usage 1; }
            REPO="$2"; shift 2 ;;
        -o)
            [[ $# -ge 2 ]] || { echo "Error: -o requires a value" >&2; usage 1; }
            OUTPUT_DIR="$2"; shift 2 ;;
        -f) FULL_LOG=true; shift ;;
        -r) RAW=true; shift ;;
        -h) usage 0 ;;
        -*) echo "Error: unknown option $1" >&2; usage 1 ;;
        *)
            if [[ -z "$WORKFLOW_ID" ]]; then
                WORKFLOW_ID="$1"
            else
                echo "Error: unexpected argument $1" >&2; usage 1
            fi
            shift ;;
    esac
done

if [[ -z "$WORKFLOW_ID" ]]; then
    echo "Error: workflow run ID is required" >&2
    usage 1
fi

mkdir -p "$OUTPUT_DIR"

OUTPUT_FILE="${OUTPUT_DIR}/${WORKFLOW_ID}.log"

# UTF-8 BOM as literal bytes (some GH Actions logs start with BOM)
BOM=$(printf '\xef\xbb\xbf')

GH_ARGS=("run" "view" "$WORKFLOW_ID" "--log" "-R" "$REPO")

echo "Saving log for workflow run $WORKFLOW_ID..."

RAW_LOG=$(gh "${GH_ARGS[@]}" 2>&1) || {
    EXIT_CODE=$?
    echo "Error: gh run view failed (exit code $EXIT_CODE)" >&2
    printf '%s\n' "$RAW_LOG" > "$OUTPUT_FILE"
    echo "Partial output saved to: $OUTPUT_FILE" >&2
    exit $EXIT_CODE
}

if [[ "$FULL_LOG" == true ]]; then
    if [[ "$RAW" == true ]]; then
        printf '%s\n' "$RAW_LOG" > "$OUTPUT_FILE"
    else
        printf '%s\n' "$RAW_LOG" \
            | sed "s/${BOM}//g" \
            | sed 's/\x1b\[[0-9;]*m//g' \
            | sed 's/\^\[\[[0-9;]*m//g' \
            | sed 's/^[^\t]*\t[^\t]*\t//' \
            | sed 's/^[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}T[0-9:.]*Z //' \
            > "$OUTPUT_FILE"
    fi
else
    FILTERED=$(printf '%s\n' "$RAW_LOG" | awk -F'\t' '$2 ~ /^Build /')

    if [[ -z "$FILTERED" ]]; then
        echo "Warning: no 'Build' step found in the log" >&2
        echo "Available steps:" >&2
        printf '%s\n' "$RAW_LOG" | awk -F'\t' '{print $2}' | sort -u | head -20 >&2
        echo "" >&2
        echo "Saving full log instead..." >&2
        if [[ "$RAW" == true ]]; then
            printf '%s\n' "$RAW_LOG" > "$OUTPUT_FILE"
        else
            printf '%s\n' "$RAW_LOG" \
                | sed "s/${BOM}//g" \
                | sed 's/\x1b\[[0-9;]*m//g' \
                | sed 's/\^\[\[[0-9;]*m//g' \
                | sed 's/^[^\t]*\t[^\t]*\t//' \
                | sed 's/^[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}T[0-9:.]*Z //' \
                > "$OUTPUT_FILE"
        fi
    else
        if [[ "$RAW" == true ]]; then
            printf '%s\n' "$FILTERED" > "$OUTPUT_FILE"
        else
            printf '%s\n' "$FILTERED" \
                | cut -f3- \
                | sed "s/${BOM}//g" \
                | sed 's/\x1b\[[0-9;]*m//g' \
                | sed 's/\^\[\[[0-9;]*m//g' \
                | sed 's/^[0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}T[0-9:.]*Z //' \
                | awk '
                    /^##\[(group|endgroup)\]/ { next }
                    /^(shell|env|with):/ { next }
                    /^  pkgbase:/ { next }
                    /^  [A-Z_]+: / { next }
                    /^[[:space:]]*$/ { next }
                    { print }
                ' \
                > "$OUTPUT_FILE"
        fi
    fi
fi

LINE_COUNT=$(wc -l < "$OUTPUT_FILE")
TOTAL_LINES=$(printf '%s\n' "$RAW_LOG" | wc -l)

if [[ "$FULL_LOG" == true ]]; then
    echo "Log saved to: $OUTPUT_FILE ($LINE_COUNT lines)"
else
    echo "Build log saved to: $OUTPUT_FILE ($LINE_COUNT lines, filtered from $TOTAL_LINES)"
fi
